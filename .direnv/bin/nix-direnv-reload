#!/usr/bin/env bash
set -e
if [[ ! -d "/home/sword/Desktop/USC/3d/hws/PROJECT" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/home/sword/Desktop/USC/3d/hws/PROJECT")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/home/sword/Desktop/USC/3d/hws/PROJECT" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/home/sword/Desktop/USC/3d/hws/PROJECT/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/home/sword/Desktop/USC/3d/hws/PROJECT/.envrc" "/home/sword/Desktop/USC/3d/hws/PROJECT/.direnv"/*.rc
